{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pg-koldstore.dev/schemas/manifest-v1.json",
  "title": "kalamdb-compatible manifest.json",
  "description": "Cold storage manifest on object storage. This is the visibility boundary for committed Parquet segments and FILE state. Temporary or final objects not referenced here are not visible to queries.",
  "type": "object",
  "required": ["version", "table", "segments", "files"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "table": {
      "type": "string"
    },
    "namespace": {
      "type": "string"
    },
    "scope_id": {
      "type": ["string", "null"],
      "description": "Scope identifier for user-scoped tables; null for shared tables"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "max_seq": {
      "type": "integer",
      "description": "Highest _seq archived in committed cold segments"
    },
    "max_commit_seq": {
      "type": "integer",
      "description": "Highest _commit_seq archived in committed cold segments"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "publish": {
      "$ref": "#/$defs/publishState"
    },
    "segments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/segment"
      }
    },
    "files": {
      "$ref": "#/$defs/filesState"
    },
    "vector_indexes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/vectorIndex"
      },
      "description": "Placeholder for kalamdb parity; out of MVP scope for pg-koldstore"
    }
  },
  "$defs": {
    "publishState": {
      "type": "object",
      "description": "Backend-specific manifest identity and publish metadata. Do not assume atomic object-store rename.",
      "properties": {
        "generation": { "type": "string" },
        "etag": { "type": "string" },
        "backend": { "type": "string" },
        "writer_id": { "type": "string" }
      }
    },
    "segment": {
      "type": "object",
      "required": [
        "batch",
        "path",
        "min_seq",
        "max_seq",
        "min_commit_seq",
        "max_commit_seq",
        "row_count",
        "schema_version"
      ],
      "properties": {
        "batch": {
          "type": "integer",
          "minimum": 0
        },
        "path": {
          "type": "string",
          "description": "Relative path, for example batch-0.parquet"
        },
        "temp_path": {
          "type": "string",
          "description": "Optional temp path retained only for diagnostics/recovery"
        },
        "min_seq": {
          "type": "integer"
        },
        "max_seq": {
          "type": "integer"
        },
        "min_commit_seq": {
          "type": "integer"
        },
        "max_commit_seq": {
          "type": "integer"
        },
        "row_count": {
          "type": "integer",
          "minimum": 0
        },
        "byte_size": {
          "type": "integer",
          "minimum": 0
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "compression": {
          "type": "string",
          "enum": ["none", "snappy", "zstd"],
          "default": "snappy"
        },
        "column_stats": {
          "type": "object",
          "description": "Per-column min/max keyed by column id or stable column name. Must include PK, _seq, _commit_seq, and configured indexed/immutable columns when supported.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "min": {},
              "max": {}
            }
          }
        },
        "pk_filter": {
          "$ref": "#/$defs/pkFilter"
        },
        "status": {
          "type": "string",
          "enum": ["committed", "compacted", "deleted"],
          "default": "committed"
        },
        "checksum": {
          "type": "string"
        },
        "etag": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "pkFilter": {
      "type": "object",
      "description": "Optional local or Parquet-backed primary-key may-contain metadata.",
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["none", "exact", "bloom", "range"]
        },
        "column_ids": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "false_positive_rate": {
          "type": "number"
        }
      }
    },
    "filesState": {
      "type": "object",
      "required": ["current_subfolder", "subfolder_count", "max_files_per_subfolder"],
      "properties": {
        "current_subfolder": {
          "type": "string"
        },
        "subfolder_count": {
          "type": "integer",
          "minimum": 0
        },
        "max_files_per_subfolder": {
          "type": "integer",
          "minimum": 1
        },
        "total_files": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "vectorIndex": {
      "type": "object",
      "description": "kalamdb vector index placeholder",
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "string" },
        "dimensions": { "type": "integer" }
      }
    }
  }
}
